\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Algorithm comparison.} Each row summarises a federated algorithm by what the server broadcasts, what clients return, architecture compatibility, and per-round communication cost. \emph  {Bottom}: heterogeneity suitability spectrum. FedMKS occupies the semi-heterogeneous niche by combining per-tier weight averaging with global soft-label exchange.}}{2}{}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:algcompare}{{1}{2}{}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Dual-head model with decoupled dual training.} A shared backbone extracts a latent vector $\mathbf  {z}\!\in \!\mathbb  {R}^d$. The \emph  {classification head} (green) is trained with cross-entropy on private labelled data $\mathcal  {D}_k^{\mathrm  {priv}}$; the \emph  {distillation head} (purple) is trained with MSE against the aggregated soft labels $\bar  {s}$ on the public set $\mathcal  {D}^{\mathrm  {pub}}$. Gradient flows are independent between heads. Backbone depth scales with tier: Small uses Conv1D$\times $3; Medium adds BiLSTM(128); Large further adds a Transformer attention block.}}{2}{}\protected@file@percent }
\newlabel{fig:dualhead}{{2}{2}{}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {CSI feature processing pipeline (\texttt  {process()}).} Per-timestep features from 52-subcarrier amplitude: mean (1 ch., time-domain), rolling variances at $W\!\in \!\{15,150,1500\}$ samples (3 ch., multi-scale), and $B{=}8$ STFT magnitude bins (1 ch., frequency-domain). The $4{+}B{=}12$ channels are stacked and slid with window $T{=}1500$ to produce the input tensor $(N_w,\,1500,\,12)$.}}{2}{}\protected@file@percent }
\newlabel{fig:csi}{{3}{2}{}{figure.3}{}}
